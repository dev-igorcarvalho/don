{
  "project-lifecycle-hooks": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "echo 'Before Model Call (PreInvocation)'",
        "timeout": 0
      }
    ],
    "PostInvocation": [
      {
        "type": "command",
        "command": "echo 'After Model Call (PostInvocation)'",
        "timeout": 0
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./.agents/hooks/stop-hook.sh",
        "timeout": 0
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Before Tool Execution'",
            "timeout": 0
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'After Tool Execution'",
            "timeout": 0
          }
        ]
      }
    ]
  }
}
