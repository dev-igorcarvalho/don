{
  "project-lifecycle-hooks": {
    "SessionStart": [
      {
        "name": "Session Start Hook",
        "type": "command",
        "command": "echo 'Session starting...'"
      },
      {
        "name": "Session Start Hook 2",
        "type": "command",
        "continue": true,
        "systemMessage" : "always greet me when you start duing anything"
      }
    ],
    "Stop": [
      {
        "name": "Session End Hook",
        "type": "command",
        "command": "echo 'Session ending...'"
      }
    ],
    "BeforeAgent": [
      {
        "name": "Before Agent Hook",
        "type": "command",
        "command": "echo 'Before Agent Execution'"
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "After Agent Hook/Linter",
            "type": "command",
            "command": "./.agents/lint.sh"
          }
        ]
      }
    ],
    "PreInvocation": [
      {
        "name": "Before Model Hook",
        "type": "command",
        "command": "echo 'Before Model Call (PreInvocation)'"
      }
    ],
    "PostInvocation": [
      {
        "name": "After Model Hook",
        "type": "command",
        "command": "echo 'After Model Call (PostInvocation)'"
      }
    ],
    "BeforeToolSelection": [
      {
        "name": "Before Tool Selection Hook",
        "type": "command",
        "command": "echo 'Before Tool Selection'"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "Before Tool Execution Hook (PreToolUse)",
            "type": "command",
            "command": "echo 'Before Tool Execution'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "After Tool Execution Hook (PostToolUse)",
            "type": "command",
            "command": "echo 'After Tool Execution'"
          }
        ]
      }
    ]
  }
}
