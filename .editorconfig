# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Don monorepo formatting standards
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go rules
[*.go]
indent_style = tab
indent_size = 4

# Makefiles
[Makefile]
indent_style = tab

# Markdown rules
[*.md]
trim_trailing_whitespace = false
